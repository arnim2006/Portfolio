# Server Port Configuration
PORT=5000

# SMTP Configuration (Default configured for Gmail)
# Note: For Gmail, use an "App Password" rather than your real password.
# To generate one: Google Account -> Security -> 2-Step Verification -> App Passwords.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=arnimagarwal7@gmail.com
SMTP_PASS=your_gmail_app_password_here

# Recipient Address (Where you want to receive the messages)
RECEIVER_EMAIL=arnimagarwal7@gmail.com
